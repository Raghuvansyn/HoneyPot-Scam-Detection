# ──────────────────────────────────────────────
# ScamBait AI — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
# ──────────────────────────────────────────────

# API Security (sent as x-api-key header)
API_KEY=your_api_key_here

# LLM Providers
CEREBRAS_API_KEY=your_cerebras_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Application Mode
# "dev"  — callbacks to GUVI disabled (local testing)
# "prod" — callbacks to GUVI enabled  (deployment)
MODE=dev

# Database
DATABASE_PATH=honeypot.db
